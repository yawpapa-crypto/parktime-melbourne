# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://parktime:parktime@localhost:5432/parktime
POSTGRES_USER=parktime
POSTGRES_PASSWORD=parktime
POSTGRES_DB=parktime

# ── Backend ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001
CORS_ORIGIN=*

# ── Mapbox (server-side only — never expose secret token to mobile) ───────────
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token
MAPBOX_SECRET_TOKEN=sk.your_mapbox_secret_token
MAPBOX_SEARCH_SESSION_TOKEN=

# Search bias: Victoria bounding box (west,south,east,north)
MAPBOX_SEARCH_BBOX=140.961681,-39.159111,149.976679,-33.980648
MAPBOX_SEARCH_PROXIMITY=144.9631,-37.8136

# ── Melbourne council data import (OpenDataSoft Explore API v2.1) ───────────
MELBOURNE_COUNCIL_API_BASE=https://data.melbourne.vic.gov.au/api/explore/v2.1
MELBOURNE_OPENDATA_API_KEY=your_melbourne_opendata_api_key
# Optional local bays file — when set and present, used instead of ODS export
MELBOURNE_BAYS_GEOJSON_PATH=./data/imports/on-street-parking-bays.geojson
MELBOURNE_IMPORT_BATCH_SIZE=500
MELBOURNE_IMPORT_SCHEDULE_CRON=0 3 * * *

# Optional dataset overrides (leave blank to use defaults)
MELBOURNE_DATASET_BAYS=on-street-parking-bays
MELBOURNE_DATASET_RESTRICTIONS=on-street-car-park-bay-restrictions
MELBOURNE_DATASET_SENSORS=on-street-parking-bay-sensors
MELBOURNE_DATASET_METERS=parking-meters
MELBOURNE_DATASET_ZONES=on-street-parking-zones

# ── Mobile (Expo public vars only) ──────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# ── Admin dashboard ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=

# ── Vercel production (set in Vercel project → Settings → Environment Variables) ──
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require   (Neon/Supabase with PostGIS)
# MAPBOX_ACCESS_TOKEN=pk....
# VITE_MAPBOX_ACCESS_TOKEN=pk....
# CORS_ORIGIN=https://your-app.vercel.app
# Leave VITE_API_BASE_URL empty on Vercel — the web app calls /api on the same domain

# ── Data quality thresholds ───────────────────────────────────────────────────
IMPORT_STALE_HOURS=48
